From f6fead9e47e59864531435cf34f61a79e093a2af Mon Sep 17 00:00:00 2001
From: Erwin Alberic Asseng <erwin.alberic@gmail.com>
Date: Sun, 19 Jul 2026 14:21:11 +0000
Subject: [PATCH] fix(cahier): retirer la colonne date inexistante de
 l'insertion operation_items

La table operation_items n'a pas de colonne date, ce qui faisait echouer
l'insertion des items a chaque enregistrement d'operation (des qu'il y en
avait au moins un), independamment de RLS. Le champ date reste sur le
modele OperationItem cote UI mais n'est plus envoye a la table.
---
 src/app/core/services/cahier.service.ts | 2 --
 1 file changed, 2 deletions(-)

diff --git a/src/app/core/services/cahier.service.ts b/src/app/core/services/cahier.service.ts
index fbb4d9c..b516cf5 100644
--- a/src/app/core/services/cahier.service.ts
+++ b/src/app/core/services/cahier.service.ts
@@ -405,7 +405,6 @@ export class CahierService {
         const dbItems = finalizedOp.items.map(item => ({
           id: item.id || crypto.randomUUID(),
           operation_id: finalizedOp.id,
-          date: item.date,
           dn: item.dn || '',
           produit: item.produit || '',
           quantite: Number(item.qte) || 0,
@@ -510,7 +509,6 @@ export class CahierService {
         const dbItems = draftOp.items.map(item => ({
           id: item.id || crypto.randomUUID(),
           operation_id: draftOp.id,
-          date: item.date,
           dn: item.dn || '',
           produit: item.produit || '',
           quantite: Number(item.qte) || 0,
-- 
2.43.0

